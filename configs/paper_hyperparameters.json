{
  "schema_version": 1,
  "description": "Consolidated effective settings for the PathoSynVLM paper pipeline and released-model inference.",
  "provenance": {
    "paper_override_sources": [
      "configs/stage1_alignment_paper.json",
      "configs/stage2_main_paper.json",
      "README.md",
      "docs/paper_pipeline.md"
    ],
    "runtime_default_sources": [
      "scripts/train_stage1_alignment.py",
      "scripts/train_stage2_histai.py",
      "scripts/evaluate_checkpoint.py",
      "scripts/generate_case_report.py",
      "pathosynvlm/alignment_model.py",
      "pathosynvlm/model.py"
    ],
    "historical_generated_train_args_committed": false,
    "interpretation": "The original run-generated train_args.json files are not committed. Each effective_arguments object below combines the committed paper overrides with the defaults used by the current implementation. New runs write their exact resolved CLI arguments to <output_dir>/train_args.json. Path placeholders must be expanded by the shell or a launcher; training scripts do not load this JSON directly."
  },
  "stage1_alignment_training": {
    "entrypoint": "scripts/train_stage1_alignment.py",
    "effective_arguments": {
      "metadata_json": "$PATHOSYNVLM_STAGE1_METADATA_DIR/merged_metadata_3datasets_filtered_conch_v15.json",
      "dataset_embeddings_root": "$PATHOSYNVLM_EMBEDDINGS_ROOT",
      "feature_key": "conch_v15",
      "patch_level": "5x_512",
      "datasets": "histgen,reg_dataset",
      "prompt_style": "single",
      "llm": "Qwen/Qwen2.5-3B-Instruct",
      "vision_dim": 768,
      "output_dir": "$PATHOSYNVLM_RUNS_ROOT/stage1_alignment",
      "seed": 42,
      "epochs": 10,
      "batch_size": 1,
      "val_size": "500",
      "split_seed": 42,
      "num_workers": 4,
      "max_text_length": 512,
      "probe_h5_on_init": false,
      "enforce_readable_h5": true,
      "grad_accum": 8,
      "aligner_lr": 0.0001,
      "weight_decay": 0.01,
      "warmup_ratio": 0.03,
      "scheduler": "cosine",
      "max_steps": -1,
      "clip_grad_norm": 1.0,
      "precision": "bf16",
      "log_every": 10,
      "val_max_batches": -1,
      "sample_count": 10,
      "save_every_epoch": 1,
      "gen_max_new_tokens": 256,
      "gen_do_sample": false,
      "gen_temperature": 0.6,
      "gen_top_p": 0.95,
      "bertscore_model_type": "roberta-large",
      "wandb": false,
      "wandb_entity": "",
      "wandb_project": "PathoSynVLM",
      "wandb_run_name": "",
      "wandb_group": "",
      "wandb_tags": "alignment,3datasets",
      "trust_remote_code": true
    },
    "model_and_trainability": {
      "vision_encoder": "precomputed CONCHv1.5 embeddings; no vision encoder is loaded or trained",
      "llm_trainable": false,
      "wsi_markers_enabled": false,
      "trainable_components": [
        "vision_aligner"
      ],
      "vision_aligner": {
        "architecture": "LayerNorm -> Linear -> GELU -> Dropout -> Linear -> LayerNorm",
        "input_dim": 768,
        "output_dim": "Qwen hidden_size",
        "mlp_hidden_dim": "4 * Qwen hidden_size",
        "dropout": 0.0,
        "layer_norm": true
      }
    },
    "optimizer_and_scheduler": {
      "optimizer": "torch.optim.AdamW",
      "betas": [
        0.9,
        0.95
      ],
      "epsilon": 1e-08,
      "learning_rate": 0.0001,
      "weight_decay": 0.01,
      "scheduler": "Hugging Face cosine schedule with warmup",
      "updates_per_epoch_formula": "ceil(number_of_train_batches / grad_accum)",
      "total_update_steps_formula": "epochs * updates_per_epoch because max_steps=-1",
      "warmup_steps_formula": "max(1, floor(total_update_steps * 0.03))",
      "gradient_accumulation_loss_scaling": "loss / grad_accum",
      "gradient_clipping_max_norm": 1.0
    },
    "batching_and_runtime": {
      "micro_batch_size": 1,
      "gradient_accumulation_steps": 8,
      "effective_batch_size": 8,
      "train_shuffle": true,
      "device": "CUDA when available, otherwise CPU",
      "cuda_autocast_dtype": "bfloat16",
      "fp16_grad_scaler_enabled": false,
      "deterministic_algorithms_enforced": false
    },
    "in_training_validation": {
      "validation_selection_size_before_readability_filter": 500,
      "validation_size_note": "Unreadable or empty H5 rows are removed after the split and are not replaced, so the evaluated set can contain fewer than 500 rows.",
      "validation_batches": "full post-filter validation set",
      "generation": {
        "max_new_tokens": 256,
        "min_new_tokens": 96,
        "min_new_tokens_source": "inherited from PathoSynVLM.generate because Stage 1 does not pass this argument",
        "do_sample": false,
        "num_beams": 1,
        "temperature": 0.6,
        "top_p": 0.95,
        "temperature_and_top_p_active": false
      },
      "metrics": [
        "ROUGE",
        "METEOR",
        "sacreBLEU",
        "BERTScore"
      ],
      "rouge_type": "rougeL",
      "rouge_use_stemmer": true,
      "bertscore_model_type": "roberta-large",
      "bertscore_language": "en",
      "bertscore_rescale_with_baseline": true,
      "bertscore_use_fast_tokenizer": true,
      "best_checkpoint_selection": "lowest validation loss"
    }
  },
  "stage2_histai_training": {
    "entrypoint": "scripts/train_stage2_histai.py",
    "effective_arguments": {
      "metadata_standardized_json": "$PATHOSYNVLM_HISTAI_METADATA_DIR/standardized_metadata_fixed_filtered_5x_512.json",
      "dataset_embeddings_root": "$PATHOSYNVLM_EMBEDDINGS_ROOT",
      "alignment_metadata_json": "$PATHOSYNVLM_STAGE1_METADATA_DIR/merged_metadata_3datasets_filtered_conch_v15.json",
      "feature_key": "conch_v15",
      "patch_level": "5x_512",
      "alignment_dataset_selection": "all",
      "alignment_mix_fraction": 0.0,
      "val_size": "0.2",
      "split_seed": 42,
      "num_workers": 4,
      "max_text_length": 384,
      "max_vision_tokens": 4096,
      "vision_token_dropout": 0.0,
      "missing_policy": "skip",
      "probe_h5_on_init": false,
      "llm": "Qwen/Qwen2.5-3B-Instruct",
      "vision_dim": 768,
      "use_wsi_markers": true,
      "use_wsi_index_emb": true,
      "prompt_style": "double",
      "alignment_prompt_style": "single",
      "report_target_field": "conclusion",
      "report_target_label": "",
      "aligner_init": "$PATHOSYNVLM_RUNS_ROOT/stage1_alignment/best_aligner_weights.pt",
      "skip_aligner_init": false,
      "strict_aligner_load": true,
      "output_dir": "$PATHOSYNVLM_RUNS_ROOT/stage2_main",
      "seed": 42,
      "epochs": 20,
      "batch_size": 1,
      "grad_accum": 8,
      "lr": 0.00002,
      "aligner_lr": 0.0001,
      "llm_base_lr": 0.000005,
      "weight_decay": 0.01,
      "warmup_ratio": 0.03,
      "scheduler": "cosine",
      "optimizer": "adamw",
      "max_steps": -1,
      "clip_grad_norm": 1.0,
      "gradient_checkpoint": true,
      "precision": "bf16",
      "ema": false,
      "ema_decay": 0.999,
      "lora_r": 16,
      "lora_alpha": 32,
      "lora_dropout": 0.05,
      "lora_target": "q_proj,k_proj,v_proj,o_proj",
      "use_lora": true,
      "freeze_aligner": false,
      "unfreeze_llm_base": true,
      "llm_train_scope": "",
      "aligner_anchor_reg_weight": 0.0,
      "llm_anchor_reg_weight": 0.0,
      "marker_anchor_reg_weight": 0.0,
      "log_every": 10,
      "eval_every": 200,
      "save_every": 500,
      "checkpoint_policy": "meaningful",
      "save_first_n": 3,
      "save_top_k": 10,
      "max_saved_checkpoints": 10,
      "val_max_batches": 30,
      "gen_max_new_tokens": 256,
      "gen_min_new_tokens": 0,
      "gen_do_sample": false,
      "gen_temperature": 0.6,
      "gen_top_p": 0.95,
      "certainty_percent_threshold": 50.0,
      "sample_count": 16,
      "bertscore_model_type": "roberta-large",
      "wandb": false,
      "wandb_entity": "",
      "wandb_project": "PathoSynVLM",
      "wandb_run_name": "",
      "wandb_group": "",
      "wandb_tags": "histai,finetune,lora"
    },
    "model_and_trainability": {
      "vision_encoder": "precomputed CONCHv1.5 embeddings; no vision encoder is loaded or trained",
      "stage1_aligner_initialization": "strict load from best_aligner_weights.pt",
      "vision_aligner": {
        "architecture": "LayerNorm -> Linear -> GELU -> Dropout -> Linear -> LayerNorm",
        "input_dim": 768,
        "output_dim": "Qwen hidden_size",
        "mlp_hidden_dim": "4 * Qwen hidden_size",
        "dropout": 0.0,
        "layer_norm": true,
        "trainable": true
      },
      "wsi_markers": {
        "shared_separator_trainable": true,
        "indexed_embeddings_trainable": true,
        "maximum_wsi_chunks": 32,
        "separator_initialization": "normal(mean=0.0, std=0.02)"
      },
      "lora": {
        "enabled": true,
        "rank": 16,
        "alpha": 32,
        "dropout": 0.05,
        "targets": [
          "q_proj",
          "k_proj",
          "v_proj",
          "o_proj"
        ],
        "bias": "none"
      },
      "resolved_llm_train_scope": "full",
      "full_llm_base_trainable": true,
      "gradient_checkpointing": true,
      "llm_use_cache_during_training": false,
      "anchor_regularization_enabled": false,
      "ema_enabled": false
    },
    "optimizer_and_scheduler": {
      "optimizer": "torch.optim.AdamW",
      "betas": [
        0.9,
        0.95
      ],
      "epsilon": 1e-08,
      "foreach": false,
      "weight_decay": 0.01,
      "parameter_groups": {
        "lora": {
          "learning_rate": 0.00002,
          "weight_decay": 0.01
        },
        "aligner": {
          "learning_rate": 0.0001,
          "weight_decay": 0.01
        },
        "wsi_markers": {
          "learning_rate": 0.0001,
          "weight_decay": 0.01
        },
        "llm_base": {
          "learning_rate": 0.000005,
          "weight_decay": 0.01
        }
      },
      "scheduler": "Hugging Face cosine schedule with warmup",
      "updates_per_epoch_formula": "ceil(number_of_train_batches_per_process / grad_accum)",
      "total_update_steps_formula": "epochs * updates_per_epoch because max_steps=-1",
      "warmup_steps_formula": "max(1, floor(total_update_steps * 0.03))",
      "gradient_accumulation_loss_scaling": "loss / grad_accum",
      "gradient_clipping_max_norm": 1.0
    },
    "batching_and_runtime": {
      "micro_batch_size_per_process": 1,
      "gradient_accumulation_steps": 8,
      "effective_batch_size_per_process": 8,
      "effective_batch_size_documented_single_process_command": 8,
      "effective_global_batch_size_formula": "8 * distributed_world_size",
      "train_shuffle": true,
      "distributed_sampler_shuffle": true,
      "distributed_sampler_drop_last": false,
      "seed_per_rank_formula": "42 + rank",
      "device": "local CUDA rank for distributed execution; otherwise CUDA when available, else CPU",
      "cuda_autocast_dtype": "bfloat16",
      "fp16_grad_scaler_enabled": false,
      "deterministic_algorithms_enforced": false
    },
    "in_training_validation": {
      "validation_split": 0.2,
      "split_seed": 42,
      "evaluation_frequency_optimizer_steps": 200,
      "also_evaluate_at_epoch_end": true,
      "maximum_batches_per_evaluation": 30,
      "maximum_cases_per_evaluation_at_batch_size_one": 30,
      "generation": {
        "max_new_tokens": 256,
        "min_new_tokens": 0,
        "do_sample": false,
        "num_beams": 1,
        "temperature": 0.6,
        "top_p": 0.95,
        "temperature_and_top_p_active": false
      },
      "metrics": [
        "ROUGE",
        "METEOR",
        "sacreBLEU",
        "BERTScore",
        "diagnosis exact match",
        "diagnosis relaxed match",
        "certainty accuracy"
      ],
      "rouge_type": "rougeL",
      "rouge_use_stemmer": true,
      "bertscore_model_type": "roberta-large",
      "bertscore_language": "en",
      "bertscore_rescale_with_baseline": true,
      "bertscore_use_fast_tokenizer": true,
      "diagnosis_relaxed_match_threshold": 0.85,
      "certainty_percent_threshold": 50.0,
      "best_checkpoint_selection": "lowest validation loss"
    },
    "checkpointing": {
      "policy": "meaningful",
      "always_consider_first_evaluated_checkpoints": 3,
      "top_ranked_evaluated_checkpoints": 10,
      "hard_cap_on_saved_step_checkpoints": 10,
      "top_rank_order": [
        "METEOR",
        "BLEU-4",
        "ROUGE-L",
        "BERTScore F1",
        "negative validation loss"
      ],
      "save_every_optimizer_steps": 500,
      "save_every_active_under_effective_policy": false,
      "save_every_note": "Periodic save_every checkpoints are only used when checkpoint_policy is all; meaningful retention saves after evaluation instead.",
      "optimizer_state_in_saved_step_checkpoints": false,
      "scheduler_state_in_saved_step_checkpoints": false,
      "full_llm_state_in_saved_step_checkpoints": false
    }
  },
  "standalone_checkpoint_evaluation": {
    "entrypoint": "scripts/evaluate_checkpoint.py",
    "effective_arguments_for_documented_histai_command": {
      "finetune_run_dir": "$PATHOSYNVLM_RUNS_ROOT/stage2_main",
      "checkpoint_step": -1,
      "dataset_scope": "histai",
      "dataset_selection": "all",
      "eval_groups": "",
      "alignment_metadata_json": "$PATHOSYNVLM_STAGE1_METADATA_DIR/merged_metadata_3datasets_filtered_conch_v15.json",
      "histai_metadata_standardized_json": "$PATHOSYNVLM_HISTAI_METADATA_DIR/standardized_metadata_fixed_filtered_5x_512.json",
      "dataset_embeddings_root": "$PATHOSYNVLM_EMBEDDINGS_ROOT",
      "feature_key": "",
      "patch_level": "",
      "val_size": "0.2",
      "split_seed": 42,
      "batch_size": 1,
      "num_workers": 4,
      "max_text_length": 512,
      "prompt_style": "",
      "gen_max_new_tokens": 256,
      "gen_min_new_tokens": 0,
      "gen_do_sample": false,
      "gen_temperature": 0.6,
      "gen_top_p": 0.95,
      "certainty_percent_threshold": 50.0,
      "max_batches": -1,
      "sample_count": 20,
      "bertscore_model_type": "roberta-large",
      "case_filter_files": "",
      "case_filter_field": "",
      "output_json": "$PATHOSYNVLM_RUNS_ROOT/stage2_main/eval_histai.json",
      "output_predictions_jsonl": null
    },
    "resolved_values": {
      "checkpoint_selection": "best_step from best_checkpoint_summary.json because checkpoint_step=-1",
      "feature_key": "conch_v15, inherited from the run train_args.json",
      "patch_level": "5x_512, inherited from the run train_args.json",
      "prompt_style": "double, inherited from the run train_args.json",
      "max_vision_tokens": 0,
      "max_vision_tokens_meaning": "uncapped; the evaluator does not expose an override",
      "validation_batches": "full selected validation split",
      "train_shuffle": false,
      "device": "CUDA when available, otherwise CPU",
      "cuda_dtype": "bfloat16",
      "cpu_dtype": "model default",
      "num_beams": 1,
      "generation_seed": null,
      "rouge_type": "rougeL",
      "rouge_use_stemmer": true,
      "bertscore_language": "en",
      "bertscore_rescale_with_baseline": true,
      "bertscore_use_fast_tokenizer": true,
      "diagnosis_relaxed_match_threshold": 0.85
    },
    "protocol_note": "These standalone evaluator defaults differ from in-training validation: text length is 512 rather than 384, vision tokens are uncapped rather than capped at 4096, and the full validation split is evaluated rather than at most 30 batches."
  },
  "released_model_inference": {
    "entrypoint": "scripts/generate_case_report.py",
    "effective_arguments": {
      "weights": "$PATHOSYNVLM_WEIGHTS_ROOT/pathosynvlm-stage2-main",
      "embedding_root": "$PATHOSYNVLM_EMBEDDINGS_ROOT",
      "embeddings": [
        "<one-or-more slide H5 files for one case>"
      ],
      "feature_key": "",
      "max_vision_tokens": 0,
      "max_new_tokens": 256,
      "min_new_tokens": 0,
      "temperature": 0.6,
      "top_p": 0.95,
      "do_sample": false,
      "device": "CUDA when available, otherwise CPU",
      "dtype": "bf16",
      "output_json": null
    },
    "paper_release_config_values": {
      "base_llm": "Qwen/Qwen2.5-3B-Instruct",
      "vision_dim": 768,
      "feature_key": "conch_v15",
      "patch_level": "5x_512",
      "use_wsi_markers": true,
      "use_wsi_index_emb": true,
      "prompt_style": "double",
      "report_target_field": "conclusion",
      "report_target_label": ""
    },
    "runtime_behavior": {
      "case_batch_size": 1,
      "slides_per_case": "one or more",
      "maximum_wsi_chunks": 32,
      "embedding_input_dtype": "float32",
      "embedding_order": "command-line order",
      "vision_token_cap_behavior": "0 means uncapped; a positive cap keeps tokens in input order until the cap is reached",
      "resolved_feature_key": "weights/config.json feature_key when the CLI value is empty, with conch_v15 as the code fallback",
      "num_beams": 1,
      "decoding": "greedy",
      "temperature_and_top_p_active": false,
      "generation_seed": null,
      "cuda_model_dtype": "requested bfloat16",
      "cpu_model_dtype": "model default; the requested dtype is not passed on CPU",
      "tokenizer": "fast tokenizer with trust_remote_code=true; pad token falls back to EOS",
      "model_mode": "eval",
      "autograd": false,
      "other_generation_parameters": "not overridden; inherited from the packaged model and Transformers generation defaults"
    }
  }
}
