{
  "description": "Paper main Stage 2 run matching Table 3: HistAI 5x_512, prompt repetition, aligner initialized from Stage 1, LoRA plus trainable LLM base.",
  "script": "scripts/train_stage2_histai.py",
  "args": {
    "metadata_standardized_json": "data/histai/standardized_metadata_fixed_filtered_5x_512.json",
    "dataset_embeddings_root": "data/embeddings",
    "feature_key": "conch_v15",
    "patch_level": "5x_512",
    "val_size": "0.2",
    "split_seed": 42,
    "max_text_length": 384,
    "max_vision_tokens": 4096,
    "vision_token_dropout": 0.0,
    "llm": "Qwen/Qwen2.5-3B-Instruct",
    "vision_dim": 768,
    "use_wsi_markers": true,
    "use_wsi_index_emb": true,
    "prompt_style": "double",
    "aligner_init": "runs/stage1_alignment/best_aligner_weights.pt",
    "epochs": 20,
    "batch_size": 1,
    "grad_accum": 8,
    "lr": 0.00002,
    "aligner_lr": 0.0001,
    "llm_base_lr": 0.000005,
    "weight_decay": 0.01,
    "warmup_ratio": 0.03,
    "scheduler": "cosine",
    "gradient_checkpoint": true,
    "precision": "bf16",
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "lora_target": "q_proj,k_proj,v_proj,o_proj",
    "use_lora": true,
    "unfreeze_llm_base": true,
    "eval_every": 200,
    "save_every": 500,
    "val_max_batches": 30,
    "gen_max_new_tokens": 256,
    "gen_min_new_tokens": 0,
    "gen_do_sample": false,
    "certainty_percent_threshold": 50.0,
    "bertscore_model_type": "roberta-large"
  }
}
