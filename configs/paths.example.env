# Optional local path defaults for PathoSynVLM.
#
# Source this file or export the same variables in your shell before running
# metadata preparation, training, evaluation, or inference. Absolute paths are
# recommended when data and embeddings live outside this repository.

export PATHOSYNVLM_DATA_ROOT="${PATHOSYNVLM_DATA_ROOT:-$PWD/data}"
export PATHOSYNVLM_RAW_DATA_ROOT="${PATHOSYNVLM_RAW_DATA_ROOT:-$PATHOSYNVLM_DATA_ROOT/raw}"
export PATHOSYNVLM_EMBEDDINGS_ROOT="${PATHOSYNVLM_EMBEDDINGS_ROOT:-$PATHOSYNVLM_DATA_ROOT/embeddings}"
export PATHOSYNVLM_STAGE1_METADATA_DIR="${PATHOSYNVLM_STAGE1_METADATA_DIR:-$PATHOSYNVLM_DATA_ROOT/stage1}"
export PATHOSYNVLM_HISTAI_METADATA_DIR="${PATHOSYNVLM_HISTAI_METADATA_DIR:-$PATHOSYNVLM_DATA_ROOT/histai}"
export PATHOSYNVLM_RUNS_ROOT="${PATHOSYNVLM_RUNS_ROOT:-$PWD/runs}"
export PATHOSYNVLM_WEIGHTS_ROOT="${PATHOSYNVLM_WEIGHTS_ROOT:-$PWD/weights}"
